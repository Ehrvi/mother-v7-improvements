# MOTHER v12.0 - Production Environment Variables
# These variables are embedded into the JavaScript bundle at BUILD TIME

# Application Identity
VITE_APP_ID=mother-interface
VITE_APP_TITLE=MOTHER v12.0
VITE_APP_LOGO=/logo.png

# OAuth Configuration
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# API Configuration (Frontend)
VITE_FRONTEND_FORGE_API_KEY=placeholder-will-be-set-by-cloud-run
VITE_FRONTEND_FORGE_API_URL=https://api.openai.com

# Analytics Configuration
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=mother-v7-production
